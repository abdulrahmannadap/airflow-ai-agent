# ── Ollama / LLM ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b-instruct-q4_K_M
FAST_LLM_MODEL=phi3:mini

# ── Apache Airflow ───────────────────────────────────────────────
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
# Path where Airflow writes logs (adjust to your setup)
AIRFLOW_LOG_DIR=./data/logs/airflow

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./airflow_agent.db

# ── Agent Behaviour ───────────────────────────────────────────────
# How often the log monitor polls (seconds)
MONITOR_INTERVAL_SECONDS=30
# How often dependency checks run after a failure (seconds)
DEPENDENCY_CHECK_INTERVAL_SECONDS=60
# Max number of retries before giving up
MAX_RETRIES=5
# Max wait time before forcing a retry (minutes)
MAX_WAIT_MINUTES=120

# ── Resource Thresholds ───────────────────────────────────────────
# Retry only when CPU usage is below this %
CPU_THRESHOLD_PERCENT=80
# Retry only when memory usage is below this %
MEMORY_THRESHOLD_PERCENT=85

# ── App ───────────────────────────────────────────────────────────
APP_NAME=Airflow AI Agent
APP_ENV=development
DEBUG=true
